# Database (Postgres — e.g. Neon, Vercel Postgres, Supabase)
# DATABASE_URL = pooled connection (used by the app at runtime)
# DIRECT_URL   = direct connection (used by Prisma Migrate)
DATABASE_URL=
DIRECT_URL=

# AI Providers (at least one required)
GROQ_API_KEY=            # Primary — fastest, free tier available
ANTHROPIC_API_KEY=       # Backup 1 — Claude
GEMINI_API_KEY=          # Backup 2 — Gemini

# YouTube transcripts (required in production / Vercel)
# YouTube blocks transcript fetches from datacenter IPs, so hosted deploys need
# a proxying transcript API. Sign up free at https://supadata.ai -> API key.
# Locally this can be left blank (falls back to the youtube-transcript library).
SUPADATA_API_KEY=

# Auth (NextAuth v5) — required
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# OAuth (optional — leave blank to use email/password only)
# Google:  https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# GitHub:  https://github.com/settings/developers (New OAuth App)
#   Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Email / OTP verification (transactional provider recommended in production —
# personal Gmail gets rate-limited and banned for sending OTPs).
# Brevo:    SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587  SMTP_USER=<login>  SMTP_PASS=<smtp key>
# SendGrid: SMTP_HOST=smtp.sendgrid.net     SMTP_PORT=587  SMTP_USER=apikey   SMTP_PASS=<api key>
# Leave SMTP_HOST blank to fall back to Gmail (dev/testing only).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=         # verified sender, e.g. "Second Brain <no-reply@yourdomain.com>"
